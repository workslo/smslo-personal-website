{
	"name": "smslo-personal-website",
	"version": "0.0.3",
	"private": true,
	"type": "module",
	"packageManager": "bun@1.2.0",
	"engines": {
		"bun": ">=1.2"
	},
	"emdash": {
		"seed": "seed/seed.json"
	},
	"scripts": {
		"preinstall": "case \"$npm_config_user_agent\" in *bun*) ;; *) echo \"\\n⚠️  Use bun to install dependencies: bun install\\n\" >&2; exit 1;; esac",
		"dev": "emdash dev",
		"build": "astro build",
		"preview": "astro preview",
		"deploy": "astro build && wrangler deploy",
		"deploy:ci": "wrangler deploy",
		"typecheck": "astro check",
		"bootstrap": "emdash init && emdash seed",
		"seed": "emdash seed"
	},
	"dependencies": {
		"@astrojs/cloudflare": "^13.1.7",
		"@astrojs/react": "^5.0.0",
		"@emdash-cms/cloudflare": "^0.12.0",
		"@emdash-cms/plugin-forms": "^0.2.0",
		"@emdash-cms/plugin-webhook-notifier": "^0.1.2",
		"astro": "^6.0.1",
		"emdash": "^0.12.0",
		"react": "19.2.6",
		"react-dom": "19.2.6"
	},
	"devDependencies": {
		"@astrojs/check": "^0.9.7",
		"@cloudflare/workers-types": "^4.20260305.1",
		"wrangler": "^4.80.0"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild",
			"workerd"
		]
	}
}
